# ============================================
# SERVIÇOS AZEVEDO - Variáveis de Produção
# ============================================
# Copie este arquivo para .env.production.local
# e preencha com os valores corretos

# ============================================
# SUPABASE
# ============================================
# URL do projeto (encontrado em Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima (encontrado em Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# APLICAÇÃO
# ============================================
# URL onde a aplicação está hospedada
NEXT_PUBLIC_APP_URL=https://seu-dominio.vercel.app

# ============================================
# VERCEL (opcional - para GitHub Actions)
# ============================================
# Token da API do Vercel
# Vercel > Settings > Tokens > Create
VERCEL_TOKEN=
